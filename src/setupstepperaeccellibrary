#include <AccelStepper.h>  

// --- Pin definitions ---
const int stepPin   = 3;  
const int dirPin    = 4;  // Tells the driver which direction to go
const int enablePin = 5;  
const int zeroPin   = 6;  // Button that sets the current position as zero

// Create a stepper object using the AccelStepper library
// AccelStepper::DRIVER tells the library we're using a step/dir driver
// stepPin and dirPin tell it which pins to pulse
AccelStepper stepper(AccelStepper::DRIVER, stepPin, dirPin);

void setup() {
  pinMode(enablePin, OUTPUT);
  // INPUT_PULLUP means the pin reads HIGH by default
  // and only goes LOW when the button connects it to GND
  // this means there in no need for an  external resistor
  pinMode(zeroPin, INPUT_PULLUP);

  // Enable the motor driver
  // Most drivers are active LOW, so LOW = enabled, HIGH = disabled
  digitalWrite(enablePin, LOW);

  // 1000 steps per second at maximum
  stepper.setMaxSpeed(1000);

  // Set how quickly the motor ramps up and slows down
  // 500 means it increases speed by 500 steps/second every second
  stepper.setAcceleration(500);

  // Declare the startup position as zero
  stepper.setCurrentPosition(0);
}

void loop() {
  // Continuously check if the zero button is being pressed
  if (digitalRead(zeroPin) == LOW) {
    reZero();  // Call the re-zero function
  }

 stepper.moveTo(1600);    -- move to step 1600
 stepper.runToPosition(); -- execute the move and wait until done
}

void reZero() {
  while (digitalRead(zeroPin) == LOW) {
    delay(10);  // Small delay to avoid hammering the pin constantly
  }

  // Small extra delay after release to filter out electrical noise
  // Mechanical buttons bounce rapidly when pressed and released
  // which can cause multiple false triggers without this
  delay(50);

  // Tell AccelStepper that wherever the motor is right now is position zero
  // All future moveTo() calls will be relative to this new zero point
  stepper.setCurrentPosition(0);
}